# Navigation PGNs

pgn 127233 "Man Overboard Notification"
pgn 127237 "Heading Track Control"
pgn 127245 "Rudder"
pgn 127252 "Heave"
pgn 129027 "Position Delta High Precision Rapid Update"
pgn 129033 "Time and Date"
pgn 129044 "Datum" fast_packet
pgn 129045 "User Datum Settings" fast_packet
# PGN 129285 is defined below with struct route_waypoint.
pgn 129291 "Set and Drift Rapid Update"
pgn 129301 "Time to from Mark" fast_packet
pgn 129302 "Bearing and Distance between two Marks" fast_packet
pgn 129538 "GNSS Control Status" fast_packet
# PGN 129540 is defined below with struct satellite_in_view.
pgn 129541 "GPS Almanac Data" fast_packet
pgn 129542 "GNSS Pseudorange Noise Statistics" fast_packet
pgn 129545 "GNSS RAIM Output" fast_packet
pgn 129547 "GNSS Pseudorange Error Statistics" fast_packet
pgn 129549 "DGNSS Corrections" fast_packet
pgn 129551 "GNSS Differential Correction Receiver Signal" fast_packet
pgn 130052 "Loran-C TD Data" fast_packet
pgn 130053 "Loran-C Range Data" fast_packet
pgn 130054 "Loran-C Signal Data" fast_packet
pgn 130060 "Label" fast_packet
pgn 130061 "Channel Source Configuration" fast_packet
pgn 130064 "Route and WP Service Database List" fast_packet
pgn 130065 "Route and WP Service Route List" fast_packet
pgn 130066 "Route and WP Service Route WP Name and Position" fast_packet
pgn 130067 "Route and WP Service Route WP Name" fast_packet
pgn 130068 "Route and WP Service XTE Limit and Navigation Method" fast_packet
pgn 130069 "Route and WP Service WP Comment" fast_packet
pgn 130070 "Route and WP Service Route Comment" fast_packet
pgn 130071 "Route and WP Service Database Comment" fast_packet
pgn 130072 "Route and WP Service Radius of Turn" fast_packet
pgn 130073 "Route and WP Service WP List WP Name and Position" fast_packet
pgn 130074 "Route and WP Service WP List Database List" fast_packet
pgn 130323 "Meteorological Station Data" fast_packet
pgn 130577 "Direction Data" fast_packet
pgn 130578 "Vessel Speed Components" fast_packet

enum HeadingReference {
  0 = "true"
  1 = "magnetic"
}

enum SpeedType {
  0 = "paddle_wheel"
  1 = "pitot_tube"
  2 = "doppler"
  3 = "correlation"
  4 = "electromagnetic"
}

enum WindReference {
  0 = "true_north"
  1 = "magnetic_north"
  2 = "apparent"
  3 = "true_boat"
  4 = "true_water"
}

enum DirectionReference {
  0 = "true"
  1 = "magnetic"
  2 = "error"
  3 = "null"
}

# PGN 127250 — Vessel Heading
pgn 127250 "Vessel Heading" interval=100ms {
  sid                uint8             :8
  heading            uint16            :16  scale=0.0001 unit="rad"  tolerance=0.01
  deviation          int16             :16  scale=0.0001 unit="rad"  tolerance=0.01
  variation          int16             :16  scale=0.0001 unit="rad"  tolerance=0.01
  heading_reference  HeadingReference  :2
  _                                    :6
}

# PGN 127251 — Rate of Turn
pgn 127251 "Rate of Turn" interval=100ms {
  sid         uint8   :8
  rate        int32   :32  scale=3.125e-8  unit="rad/s"  tolerance=0.005
  _                   :24
}

# PGN 127257 — Attitude
pgn 127257 "Attitude" interval=1000ms {
  sid    uint8   :8
  yaw    int16   :16  scale=0.0001 unit="rad" tolerance=0.01
  pitch  int16   :16  scale=0.0001 unit="rad" tolerance=0.005
  roll   int16   :16  scale=0.0001 unit="rad" tolerance=0.005
  _               :8
}

# PGN 127258 — Magnetic Variation
pgn 127258 "Magnetic Variation" interval=1000ms {
  sid              uint8               :8
  source           HeadingReference    :4
  _                                    :4
  days_since_1970  uint16              :16
  variation        int16               :16  scale=0.0001 unit="rad"
  _                                    :16
}

# PGN 128259 — Speed, Water Referenced
pgn 128259 "Speed Water Referenced" interval=1000ms {
  sid           uint8      :8
  speed_water   uint16     :16  scale=0.01 unit="m/s"
  speed_ground  uint16     :16  scale=0.01 unit="m/s"
  speed_type    SpeedType  :4
  _                        :4
  _                        :8
}

# PGN 128267 — Water Depth
pgn 128267 "Water Depth" interval=1000ms {
  sid          uint8   :8
  depth        uint32  :32  scale=0.01    unit="m"  tolerance=0.1
  offset       int16   :16  scale=0.001   unit="m"
  range        uint8   :8   scale=10      unit="m"
}

# PGN 128275 — Distance Log
pgn 128275 "Distance Log" fast_packet interval=1000ms {
  days_since_1970  uint16  :16
  seconds_today    uint32  :32  scale=0.0001 unit="s"
  log              uint32  :32  scale=1      unit="m"
  trip_log         uint32  :32  scale=1      unit="m"
}

# PGN 129025 — Position, Rapid Update
pgn 129025 "Position Rapid Update" interval=100ms {
  latitude   int32  :32  scale=1e-7 unit="deg"
  longitude  int32  :32  scale=1e-7 unit="deg"
}

# PGN 129026 — COG & SOG, Rapid Update
pgn 129026 "COG SOG Rapid Update" interval=250ms {
  sid                  uint8               :8
  cog_reference        HeadingReference    :2
  _                                        :6
  cog                  uint16              :16  scale=0.0001 unit="rad"  tolerance=0.05
  sog                  uint16              :16  scale=0.01   unit="m/s"  tolerance=0.1
  _                                        :16
}

# PGN 129029 — GNSS Position Data (fast-packet)
pgn 129029 "GNSS Position Data" fast_packet interval=1000ms {
  sid              uint8   :8
  days_since_1970  uint16  :16
  seconds_today    uint32  :32  scale=0.0001 unit="s"
  latitude         int64   :64  scale=1e-16  unit="deg"
  longitude        int64   :64  scale=1e-16  unit="deg"
  altitude         int64   :64  scale=1e-6   unit="m"
  gnss_type        uint8   :4
  gnss_method      uint8   :4
  integrity        uint8   :2
  _                         :6
  num_svs          uint8   :8
  hdop             int16   :16  scale=0.01
  pdop             int16   :16  scale=0.01
  geoidal_sep      int32   :32  scale=0.01   unit="m"
  num_ref_stations uint8   :8
}

# PGN 129283 — Cross Track Error
pgn 129283 "Cross Track Error" interval=1000ms {
  sid       uint8   :8
  xte_mode  uint8   :4
  _                  :2
  nav_term  uint8   :2
  xte       int32   :32  scale=0.01 unit="m"
  _                  :16
}

# PGN 129284 — Navigation Data (fast-packet)
pgn 129284 "Navigation Data" fast_packet interval=1000ms {
  sid                        uint8   :8
  distance_to_wp             uint32  :32  scale=0.01    unit="m"
  bearing_reference          DirectionReference :2
  perp_crossed               uint8   :2
  arrival_circle_entered     uint8   :2
  calc_type                  uint8   :2
  eta_time                   uint32  :32  scale=0.0001  unit="s"
  eta_date                   uint16  :16
  bearing_origin_to_dest     uint16  :16  scale=0.0001  unit="rad"
  bearing_position_to_dest   uint16  :16  scale=0.0001  unit="rad"
  origin_wp_number           uint32  :32
  dest_wp_number             uint32  :32
  dest_latitude              int32   :32  scale=1e-7    unit="deg"
  dest_longitude             int32   :32  scale=1e-7    unit="deg"
  wp_closing_velocity        int16   :16  scale=0.01    unit="m/s"
}

# PGN 129539 — GNSS DOPs
pgn 129539 "GNSS DOPs" interval=1000ms {
  sid            uint8   :8
  desired_mode   uint8   :3
  actual_mode    uint8   :3
  _                       :2
  hdop           int16   :16  scale=0.01
  vdop           int16   :16  scale=0.01
  tdop           int16   :16  scale=0.01
}

# PGN 129285 — Navigation Route WP Information (variable-length)
# Struct for each waypoint entry: ID, STRING_LAU name, lat/lon.

struct route_waypoint {
  id         uint16      :16
  name       string_lau
  latitude   int32       :32  scale=1e-7 unit="deg"
  longitude  int32       :32  scale=1e-7 unit="deg"
}

pgn 129285 "Navigation Route WP Information" fast_packet {
  start_rps              uint16  :16
  items                  uint16  :16
  database_id            uint16  :16
  route_id               uint16  :16
  navigation_direction   uint8   :3
  supplementary_data     uint8   :2
  _                               :3
  route_name             string_lau
  _                               :8
  waypoints              route_waypoint  repeat=items
}

# PGN 129540 — GNSS Satellites in View (variable-length)
# 3-byte header + 12 bytes per satellite entry.

struct satellite_in_view {
  prn              uint8   :8
  elevation        int16   :16  scale=0.0001 unit="rad"
  azimuth          uint16  :16  scale=0.0001 unit="rad"
  snr              int16   :16  scale=0.01   unit="dB"
  range_residuals  int32   :32  scale=0.00001 unit="m"
  status           uint8   :4
  _                         :4
}

pgn 129540 "GNSS Sats in View" fast_packet {
  sid                  uint8               :8
  range_residual_mode  uint8               :2
  _                                        :6
  sats_in_view         uint8               :8
  satellites           satellite_in_view   repeat=sats_in_view
}
