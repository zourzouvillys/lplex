# AIS PGNs (all fast-packet)

enum AISTransceiver {
  0 = "channel_a_vdl"
  1 = "channel_b_vdl"
  2 = "channel_a_coupler"
  3 = "channel_b_coupler"
  4 = "own_information"
}

enum NavStatus {
  0 = "under_way_using_engine"
  1 = "at_anchor"
  2 = "not_under_command"
  3 = "restricted_manoeuverability"
  4 = "constrained_by_draught"
  5 = "moored"
  6 = "aground"
  7 = "engaged_in_fishing"
  8 = "under_way_sailing"
  14 = "ais_sart"
  15 = "not_defined"
}

enum PositionFixType {
  0 = "undefined"
  1 = "gps"
  2 = "glonass"
  3 = "combined_gps_glonass"
  4 = "loran_c"
  5 = "chayka"
  6 = "integrated_navigation"
  7 = "surveyed"
  8 = "galileo"
}

# PGN 129038 — AIS Class A Position Report
pgn 129038 "AIS Class A Position Report" fast_packet {
  message_id            uint8   :6
  repeat_indicator      uint8   :2
  user_id               uint32  :32
  longitude             int32   :32  scale=1e-7   unit="deg"
  latitude              int32   :32  scale=1e-7   unit="deg"
  position_accuracy     uint8   :1
  raim                  uint8   :1
  time_stamp            uint8   :6
  cog                   uint16  :16  scale=0.0001 unit="rad"
  sog                   uint16  :16  scale=0.01   unit="m/s"
  communication_state   uint32  :19
  ais_transceiver_info  AISTransceiver :5
  heading               uint16  :16  scale=0.0001 unit="rad"
  rate_of_turn          int16   :16  scale=3.125e-5 unit="rad/s"
  nav_status            NavStatus :4
  _                              :4
  sid                   uint8   :8
}

# PGN 129039 — AIS Class B Position Report
pgn 129039 "AIS Class B Position Report" fast_packet {
  message_id            uint8   :6
  repeat_indicator      uint8   :2
  user_id               uint32  :32
  longitude             int32   :32  scale=1e-7   unit="deg"
  latitude              int32   :32  scale=1e-7   unit="deg"
  position_accuracy     uint8   :1
  raim                  uint8   :1
  time_stamp            uint8   :6
  cog                   uint16  :16  scale=0.0001 unit="rad"
  sog                   uint16  :16  scale=0.01   unit="m/s"
  communication_state   uint32  :19
  ais_transceiver_info  AISTransceiver :5
  heading               uint16  :16  scale=0.0001 unit="rad"
  regional_application  uint8   :8
  regional_flags        uint8   :2
  unit_type             uint8   :1
  integrated_display    uint8   :1
  dsc_flag              uint8   :1
  band                  uint8   :1
  can_handle_msg22      uint8   :1
  ais_mode              uint8   :1
  ais_comm_state        uint8   :1
  _                              :7
}

pgn 129040 "AIS Class B Extended Position Report" fast_packet

# PGN 129041 — AIS Aids to Navigation Report
pgn 129041 "AIS Aids to Navigation Report" fast_packet {
  message_id                uint8   :6
  repeat_indicator          uint8   :2
  user_id                   uint32  :32
  longitude                 int32   :32  scale=1e-7   unit="deg"
  latitude                  int32   :32  scale=1e-7   unit="deg"
  position_accuracy         uint8   :1
  raim                      uint8   :1
  time_stamp                uint8   :6
  aton_structure_length     uint16  :16  scale=0.1    unit="m"
  aton_structure_beam       uint16  :16  scale=0.1    unit="m"
  position_ref_starboard    uint16  :16  scale=0.1    unit="m"
  position_ref_true_north   uint16  :16  scale=0.1    unit="m"
  aton_type                 uint8   :5
  off_position_indicator    uint8   :1
  virtual_aton_flag         uint8   :1
  assigned_mode_flag        uint8   :1
  _                                  :1
  position_fix_type         PositionFixType :4
  _                                  :3
  aton_status               uint8   :8
  ais_transceiver_info      AISTransceiver :5
  _                                  :3
  ?                                  :16
  aton_name                 string  :160  trim="@ "
  aton_name_extension       string  :112  trim="@ "
}

pgn 129792 "AIS DGNSS Broadcast Binary Message" fast_packet

# PGN 129793 — AIS UTC and Date Report
pgn 129793 "AIS UTC and Date Report" fast_packet {
  message_id            uint8   :6
  repeat_indicator      uint8   :2
  user_id               uint32  :32
  longitude             int32   :32  scale=1e-7   unit="deg"
  latitude              int32   :32  scale=1e-7   unit="deg"
  position_accuracy     uint8   :1
  raim                  uint8   :1
  _                              :6
