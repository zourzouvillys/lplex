  position_date         uint16  :16
  _                              :4
  gnss_type             uint8   :4
  _                              :8
  _                              :8
}

# PGN 129794 — AIS Class A Static and Voyage Related Data
pgn 129794 "AIS Class A Static and Voyage Related Data" fast_packet {
  message_id              uint8   :6
  repeat_indicator        uint8   :2
  user_id                 uint32  :32
  imo_number              uint32  :32
  callsign                string  :56   trim="@ "
  name                    string  :160  trim="@ "
  ship_type               uint8   :8
  ship_length             uint16  :16  scale=0.1    unit="m"
  ship_beam               uint16  :16  scale=0.1    unit="m"
  position_ref_starboard  uint16  :16  scale=0.1    unit="m"
  position_ref_bow        uint16  :16  scale=0.1    unit="m"
  eta_date                uint16  :16
  eta_time                uint32  :32  scale=0.0001 unit="s"
  draught                 uint16  :16  scale=0.01   unit="m"
  destination             string  :160  trim="@ "
  ais_version_indicator   uint8   :2
  gnss_type               PositionFixType :4
  dte                     uint8   :1
  _                               :1
  ais_transceiver_info    AISTransceiver :5
  _                               :3
}
