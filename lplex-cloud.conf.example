# lplex-cloud configuration
#
# Copy to ./lplex-cloud.conf or /etc/lplex-cloud/lplex-cloud.conf
# CLI flags override values set here.
#
# Two modes:
#   1. ACME mode (recommended): single port with Let's Encrypt TLS.
#      Set acme.domain to enable. gRPC and HTTP multiplexed on one port.
#   2. Dual-port mode: separate gRPC and HTTP ports with self-managed certs.
#      Set grpc.listen + grpc.tls.* to enable.

# --- ACME mode (single port, Let's Encrypt) ---
# listen = ":443"
# acme {
#   domain = "lplex.dockwise.app"
#   email = ""
# }
# tls {
#   client-ca = "/etc/lplex-cloud/ca.crt"   # CA for mTLS (optional, gRPC clients)
# }

# --- Dual-port mode (self-managed certs) ---
grpc {
  listen = ":9443"

  tls {
    # Server certificate and key
    cert = "/etc/lplex-cloud/server.crt"
    key = "/etc/lplex-cloud/server.key"

    # CA certificate for client verification (mTLS)
    client-ca = "/etc/lplex-cloud/ca.crt"
  }
}

http {
  listen = ":8080"
}

# Data directory for instance state and journals
data-dir = "/data/lplex"

# Journal retention and archival (all optional, comment out to disable)
journal {

  # Retention policy (applied per-instance journal directory)
  retention {
    # Delete files older than this (ISO 8601, e.g. P30D = 30 days)
    # max-age = P30D

    # Never delete files younger than this, unless max-size is exceeded
    # min-keep = PT24H

    # Hard size cap in bytes per instance; delete oldest files when total exceeds this
    # max-size = 10737418240

    # Proactive archive threshold as % of max-size (1-99, default 80).
    # When total size exceeds this %, non-archived files are queued for
    # archive before hitting the hard cap. Only effective with max-size
    # and an archive command configured.
    # soft-pct = 80

    # What to do when the hard cap is hit and archives have failed:
    #   delete-unarchived  - delete files even if not archived (default)
    #   pause-recording    - stop journal writes until archives free space
    # overflow-policy = delete-unarchived
  }

  # Archive script (optional, comment out to disable)
  archive {
    # Path to archive script. Receives file paths as args, JSONL on stdin.
    # Must output JSONL with per-file status on stdout.
    # command = /usr/local/bin/archive-to-s3

    # When to archive: "on-rotate" (immediately) or "before-expire" (lazy)
    # trigger = on-rotate
  }
}
