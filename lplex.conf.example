# lplex configuration
#
# Copy to ./lplex.conf or /etc/lplex/lplex.conf
# CLI flags override values set here.

# SocketCAN interface name
interface = can0

# HTTP listen port
port = 8089

# Max client buffer duration (ISO 8601)
max-buffer-duration = PT5M

# Journal recording (comment out to disable)
journal {

  # Directory for journal files (required to enable journaling)
  dir = /var/log/lplex

  # File name prefix
  prefix = nmea2k

  # Block size in bytes (power of 2, min 4096)
  block-size = 262144

  # Block compression: none, zstd, zstd-dict
  compression = zstd

  rotate {
    # Rotate after duration (ISO 8601, e.g. PT1H)
    duration = PT1H

    # Rotate after bytes (0 = disabled)
    size = 0
  }
}
