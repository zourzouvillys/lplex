# lplex configuration
#
# Copy to ./lplex.conf or /etc/lplex/lplex.conf
# CLI flags override values set here.

# SocketCAN interface name
interface = can0

# HTTP listen port
port = 8089

# Max client buffer duration (ISO 8601)
max-buffer-duration = PT5M

# Send policy: controls whether HTTP clients can transmit CAN frames
# via /send and /query. Disabled by default; enable explicitly.
# Does NOT affect internal device discovery (ISO requests on startup).
send {
  # Set to true to enable the /send and /query endpoints.
  # With no rules, all PGNs and destinations are allowed.
  # enabled = true

  # Ordered rules evaluated top-to-bottom; first match wins.
  # No matching rule = deny. Empty list + enabled = allow all.
  #
  # Rules can be strings (DSL syntax) or objects. Both forms can be mixed.
  #
  # String form: [!] [pgn:<spec>] [name:<hex>,...]
  #   PGN specs: values (59904), lists (59904,126208), ranges (65280-65535)
  #   NAME specs: comma-separated 64-bit hex CAN NAMEs
  #   ! prefix = deny
  #
  # Object form: { deny = true/false, pgn = "<spec>", name = "<hex>" or ["<hex>", ...] }
  #   All fields optional; at least one required.
  #
  # rules = [
  #   "!pgn:65280-65535"                             # string: deny proprietary PGNs
  #   "pgn:59904"                                    # string: allow ISO Request
  #   { pgn = "126208", name = "001c6e4000200000" }  # object: PGN + single device
  #   { pgn = "129025-129029", name = [              # object: PGN range + device list
  #     "001c6e4000200000"
  #     "001c6e4000200001"
  #   ]}
  #   { deny = true }                                # object: catch-all deny
  # ]
}

# Alert when no CAN frames received for this duration (ISO 8601).
# Detects CAN bus disconnection or power issues.
# bus-silence-timeout = PT30S

# Journal recording (comment out to disable)
journal {

  # Directory for journal files (required to enable journaling)
  dir = /var/log/lplex

  # File name prefix
  prefix = nmea2k

  # Block size in bytes (power of 2, min 4096)
  block-size = 262144

  # Block compression: none, zstd, zstd-dict
  compression = zstd

  rotate {
    # Rotate after duration (ISO 8601, e.g. PT1H)
    duration = PT1H

    # Rotate after bytes (0 = disabled)
    size = 0
  }

  # Retention policy (all optional, comment out to disable)
  retention {
    # Delete files older than this (ISO 8601, e.g. P30D = 30 days)
    # max-age = P30D

    # Never delete files younger than this, unless max-size is exceeded
    # min-keep = PT24H

    # Hard size cap in bytes; delete oldest files when total exceeds this
    # max-size = 10737418240

    # Proactive archive threshold as % of max-size (1-99, default 80).
    # When total size exceeds this %, non-archived files are queued for
    # archive before hitting the hard cap. Only effective with max-size
    # and an archive command configured.
    # soft-pct = 80

    # What to do when the hard cap is hit and archives have failed:
    #   delete-unarchived  - delete files even if not archived (default)
    #   pause-recording    - stop journal writes until archives free space
    # overflow-policy = delete-unarchived
  }

  # Archive script (optional, comment out to disable)
  archive {
    # Path to archive script. Receives file paths as args, JSONL on stdin.
    # Must output JSONL with per-file status on stdout.
    # command = /usr/local/bin/archive-to-s3

    # When to archive: "on-rotate" (immediately) or "before-expire" (lazy)
    # trigger = on-rotate
  }
}

# Cloud replication (comment out to disable)
# replication {
#   target = "lplex.example.com:9443"
#   instance-id = "boat-001"
#   tls {
#     cert = "/etc/lplex/boat-001.crt"
#     key = "/etc/lplex/boat-001.key"
#     ca = "/etc/lplex/ca.crt"
#   }
#
#   # Resource protection tuning (defaults are usually fine)
#   # max-live-lag = 10000               # frames before switching to backfill
#   # lag-check-interval = 1000          # check lag every N frames sent
#   # min-lag-reconnect-interval = "30s" # throttle between lag-triggered reconnects
# }
